      <trkpt lat="50.8697" lon="3.5683"><name>Wijnpers</name></trkpt>
      <trkpt lat="50.8583" lon="3.6083"><name>Koppenberg</name></trkpt>
      <trkpt lat="50.8558" lon="3.5986"><name>Oude Kwaremont (1st)</name></trkpt>
